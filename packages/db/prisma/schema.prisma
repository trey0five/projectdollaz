// ─────────────────────────────────────────────────────────────────────────────
// @finrep/db — Phase-1 data model (Prisma + Postgres).
//
// TENANT ISOLATION CONTRACT:
//   organizations 1─< schools (THE TENANT) 1─< every domain table (school_id).
//   Users are GLOBAL identities; their access to a tenant is granted via
//   `memberships (user_id, school_id, role)`. Every domain table therefore
//   carries `school_id`, and `schools` carries `organization_id`.
//
// REPRODUCIBILITY CONTRACT:
//   A statement_snapshot is a DERIVED artifact. It is fully reproducible from:
//     (1) the IMMUTABLE `imports.rows` JSONB snapshot (the parsed NormalizedRow[]
//         captured at upload time and never mutated), PLUS
//     (2) the `mappings.version` used (account -> SCoA category), PLUS
//     (3) the `standard_chart_versions.version` (the SCoA chart), PLUS
//     (4) the `engine_version` (the @finrep/engine semver that produced it).
//   Re-running generateReports(import.rows, mapping@version, chart@version) on the
//   same engine_version MUST yield byte-identical `payload`. Imports are append-
//   only and never edited; corrections create a NEW import. Mappings and charts
//   are versioned (never updated in place) so historical snapshots stay valid.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  // Pin the engine binary target to the container runtime (node:22-slim =
  // Debian, OpenSSL 3.x). Deterministic: the build stage downloads exactly the
  // engine the runner needs, avoiding a "native" target mismatch and shipping
  // only the one binary. Local dev on the same platform still works; add your
  // platform here if generating on a different OS.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum MembershipRole {
  owner
  accountant
  viewer
}

enum MembershipStatus {
  active
  invited
}

enum ImportRole {
  cy
  py
  audit
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  none
}

// ── Tenancy ──────────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  schools          School[]
  auditLog         AuditLog[]
  orgQboConnection OrgQboConnection?

  @@map("organizations")
}

/// The TENANT. Every domain table below is scoped by school_id.
model School {
  id                  String   @id @default(uuid()) @db.Uuid
  organizationId      String   @map("organization_id") @db.Uuid
  name                String
  // Beginning net-asset balances the engine needs to roll the SOA forward
  // (per-school). Decimal in the DB; converted to plain `number` at the API
  // boundary to match the engine's SchoolConfig (which uses number).
  netAssetsBegin      Decimal  @default(0) @map("net_assets_begin") @db.Decimal(18, 2)
  pyNetAssetsBegin    Decimal  @default(0) @map("py_net_assets_begin") @db.Decimal(18, 2)
  auditNetAssetsBegin Decimal  @default(0) @map("audit_net_assets_begin") @db.Decimal(18, 2)
  // Phase-1 Board Report branding (all nullable, additive). logoBase64 holds the
  // full data URL (size-guarded in the DTO + service); brandColor an optional hex
  // accent; defaultCommittee the committee-name prefill for new board reports.
  logoBase64          String?  @map("logo_base64") @db.Text
  brandColor          String?  @map("brand_color")
  defaultCommittee    String?  @map("default_committee")
  // School Comparison — peer-benchmarking profile (all nullable, additive; no backfill).
  // schoolType validated in the DTO (not a DB enum — cheap migrations, like periodType).
  // gradeLow/High are GradeKey strings (PK3,PK4,K,1..12) — same vocab as plannedEnrollmentByGrade.
  // Size band is NEVER stored: derived from PeriodOperationalData.enrollment at read time.
  county              String?  @map("county")
  district            String?  @map("district")
  schoolType          String?  @map("school_type")
  gradeLow            String?  @map("grade_low")
  gradeHigh           String?  @map("grade_high")
  createdAt           DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  fiscalPeriods            FiscalPeriod[]
  memberships              Membership[]
  invitations              Invitation[]
  imports                  Import[]
  mappings                 Mapping[]
  statementSnapshots       StatementSnapshot[]
  subscription             Subscription?
  auditLog                 AuditLog[]
  operationalData          PeriodOperationalData[]
  complianceInputs         PeriodComplianceInputs[]
  scholarshipDisbursements ScholarshipDisbursement[]
  correctiveActions        PeriodCorrectiveAction[]
  checklistItems           PeriodChecklistItem[]
  insights                 PeriodInsight[]
  budgets                  PeriodBudget[]
  analyticsDashboard       AnalyticsDashboard?
  reportSchedule           ReportSchedule?
  alerts                   Alert[]
  qboConnection            QboConnection?
  boardReports             BoardReport[]
  capitalSchedules         CapitalSchedule[]
  cashSchedules            CashSchedule[]
  campaignSchedules        CampaignSchedule[]
  monthlySnapshots         MonthlySnapshot[]
  policies                 Policy[]
  committees               Committee[]
  meetings                 Meeting[]
  tasks                    Task[]
  accreditationStandards   AccreditationStandard[]
  accreditationEvidence    AccreditationEvidence[]
  maintenanceItems         MaintenanceItem[]
  campaigns                AdvancementCampaign[]
  advancementGifts         AdvancementGift[]
  documents                KnowledgeDocument[]
  orgQboMappings           OrgQboMapping[]
  enrollmentSources        EnrollmentSource[]
  enrollmentSnapshots      EnrollmentSnapshot[]
  arApAgingSnapshots       ArApAgingSnapshot[]
  cashFlowSnapshots        CashFlowSnapshot[]
  strategicPlans           StrategicPlan[]
  strategyPillars          StrategyPillar[]
  strategyGoals            StrategyGoal[]
  strategyInitiatives      StrategyInitiative[]

  @@index([organizationId])
  @@map("schools")
}

model FiscalPeriod {
  id            String   @id @default(uuid()) @db.Uuid
  schoolId      String   @map("school_id") @db.Uuid
  label         String
  periodEndDate DateTime @map("period_end_date") @db.Date
  periodType    String   @map("period_type")
  createdAt     DateTime @default(now()) @map("created_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  imports                  Import[]
  statementSnapshots       StatementSnapshot[]
  operationalData          PeriodOperationalData[]
  complianceInputs         PeriodComplianceInputs[]
  scholarshipDisbursements ScholarshipDisbursement[]
  correctiveActions        PeriodCorrectiveAction[]
  checklistItems           PeriodChecklistItem[]
  insights                 PeriodInsight[]
  budgets                  PeriodBudget[]
  boardReports             BoardReport[]
  capitalSchedules         CapitalSchedule[]
  cashSchedules            CashSchedule[]
  campaignSchedules        CampaignSchedule[]
  monthlySnapshots         MonthlySnapshot[]
  enrollmentSnapshots      EnrollmentSnapshot[]

  // Phase 1C: DB-level idempotency for create-or-get under concurrency. The
  // natural key of a period is (school, period-end, type).
  @@unique([schoolId, periodEndDate, periodType])
  @@index([schoolId])
  @@map("fiscal_periods")
}

// ── Identity & access (SCHEMA ONLY — auth LOGIC is Phase 1B) ──────────────────

model User {
  id                         String    @id @default(uuid()) @db.Uuid
  email                      String    @unique
  firstName                  String?   @map("first_name")
  lastName                   String?   @map("last_name")
  // PBKDF2 credential material (algo/iters/salt/hash). Hashing LOGIC = Phase 1B.
  passwordAlgo               String?   @map("password_algo")
  passwordIters              Int?      @map("password_iters")
  passwordSalt               Bytes?    @map("password_salt")
  passwordHash               Bytes?    @map("password_hash")
  emailVerified              Boolean   @default(false) @map("email_verified")
  emailVerificationToken     String?   @map("email_verification_token")
  emailVerificationExpiresAt DateTime? @map("email_verification_expires_at")
  passwordResetCode          String?   @map("password_reset_code")
  passwordResetExpiresAt     DateTime? @map("password_reset_expires_at")
  failedLoginAttempts        Int       @default(0) @map("failed_login_attempts")
  lockedUntil                DateTime? @map("locked_until")
  createdAt                  DateTime  @default(now()) @map("created_at")

  memberships                  Membership[]
  refreshTokens                RefreshToken[]
  imports                      Import[]                 @relation("ImportUploadedBy")
  invitedMemberships           Membership[]             @relation("MembershipInvitedBy")
  auditLog                     AuditLog[]
  operationalUpdates           PeriodOperationalData[]  @relation("OperationalUpdatedBy")
  complianceInputsUpdates      PeriodComplianceInputs[] @relation("ComplianceInputsUpdatedBy")
  correctiveActionUpdates      PeriodCorrectiveAction[] @relation("CorrectiveActionUpdatedBy")
  checklistUpdates             PeriodChecklistItem[]    @relation("ChecklistUpdatedBy")
  dashboardUpdates             AnalyticsDashboard[]     @relation("DashboardUpdatedBy")
  boardReportUpdates           BoardReport[]            @relation("BoardReportUpdatedBy")
  capitalSchedulesUpdated      CapitalSchedule[]        @relation("CapitalScheduleUpdatedBy")
  cashSchedulesUpdated         CashSchedule[]           @relation("CashScheduleUpdatedBy")
  campaignSchedulesUpdated     CampaignSchedule[]       @relation("CampaignScheduleUpdatedBy")
  monthlySnapshotsUploaded     MonthlySnapshot[]        @relation("MonthlySnapshotUploadedBy")
  policyUpdates                Policy[]                 @relation("PolicyUpdatedBy")
  committeeUpdates             Committee[]              @relation("CommitteeUpdatedBy")
  meetingUpdates               Meeting[]                @relation("MeetingUpdatedBy")
  meetingMinutesApproved       Meeting[]                @relation("MeetingMinutesApprovedBy")
  tasksAssigned                Task[]                   @relation("TaskAssignee")
  tasksCreated                 Task[]                   @relation("TaskCreatedBy")
  tasksToApprove               Task[]                   @relation("TaskApprover")
  tasksDecided                 Task[]                   @relation("TaskDecidedBy")
  accreditationStandardUpdates AccreditationStandard[]  @relation("AccreditationStandardUpdatedBy")
  accreditationEvidenceCreated AccreditationEvidence[]  @relation("AccreditationEvidenceCreatedBy")
  maintenanceItemsCreated      MaintenanceItem[]        @relation("MaintenanceItemCreatedBy")
  advancementCampaignsCreated  AdvancementCampaign[]    @relation("AdvancementCampaignCreatedBy")
  advancementGiftsCreated      AdvancementGift[]        @relation("AdvancementGiftCreatedBy")
  knowledgeDocumentsUploaded   KnowledgeDocument[]      @relation("KnowledgeDocumentUploadedBy")
  alertsCreated                Alert[]                  @relation("AlertCreatedBy")
  enrollmentSnapshotsCreated   EnrollmentSnapshot[]     @relation("EnrollmentSnapshotCreatedBy")
  strategicPlanUpdates         StrategicPlan[]          @relation("StrategicPlanUpdatedBy")
  strategyPillarUpdates        StrategyPillar[]         @relation("StrategyPillarUpdatedBy")
  strategyGoalUpdates          StrategyGoal[]           @relation("StrategyGoalUpdatedBy")
  strategyGoalsOwned           StrategyGoal[]           @relation("StrategyGoalOwner")
  strategyInitiativeUpdates    StrategyInitiative[]     @relation("StrategyInitiativeUpdatedBy")
  strategyInitiativesOwned     StrategyInitiative[]     @relation("StrategyInitiativeOwner")

  @@index([email])
  @@map("users")
}

model Membership {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  schoolId  String           @map("school_id") @db.Uuid
  role      MembershipRole
  status    MembershipStatus @default(active)
  invitedBy String?          @map("invited_by") @db.Uuid
  createdAt DateTime         @default(now()) @map("created_at")

  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  school        School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  invitedByUser User?  @relation("MembershipInvitedBy", fields: [invitedBy], references: [id], onDelete: SetNull)

  @@unique([userId, schoolId])
  @@index([schoolId])
  @@index([userId])
  @@map("memberships")
}

model Invitation {
  id         String         @id @default(uuid()) @db.Uuid
  schoolId   String         @map("school_id") @db.Uuid
  email      String
  role       MembershipRole
  token      String         @unique
  orgWide    Boolean        @default(false) @map("org_wide")
  expiresAt  DateTime       @map("expires_at")
  acceptedAt DateTime?      @map("accepted_at")
  createdAt  DateTime       @default(now()) @map("created_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([email])
  @@map("invitations")
}

model RefreshToken {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  token          String    @unique
  /// Refresh token JWT id. Surfaced in the paired access token's `sid` claim so
  /// activity-touch can target the exact session (precise multi-session accounting).
  jti            String?   @unique
  expiresAt      DateTime  @map("expires_at")
  revokedAt      DateTime? @map("revoked_at")
  lastActivityAt DateTime? @map("last_activity_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ── Ingest & derivation ───────────────────────────────────────────────────────

/// IMMUTABLE raw snapshot. `rows` is the parsed NormalizedRow[] captured at
/// upload time and never mutated — the reproducibility anchor.
model Import {
  id             String     @id @default(uuid()) @db.Uuid
  schoolId       String     @map("school_id") @db.Uuid
  fiscalPeriodId String     @map("fiscal_period_id") @db.Uuid
  role           ImportRole
  sourceName     String     @map("source_name")
  rows           Json       @db.JsonB // NormalizedRow[] — immutable snapshot
  metadata       Json?      @db.JsonB // SheetMetadata from @finrep/ingestion
  rowCount       Int        @map("row_count")
  uploadedBy     String?    @map("uploaded_by") @db.Uuid
  createdAt      DateTime   @default(now()) @map("created_at")

  school         School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  fiscalPeriod   FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id], onDelete: Cascade)
  uploadedByUser User?        @relation("ImportUploadedBy", fields: [uploadedBy], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([fiscalPeriodId])
  // Phase 1C: fast latest-active-per-role lookups for comparative resolution.
  @@index([fiscalPeriodId, role, createdAt])
  @@map("imports")
}

/// Versioned global SCoA chart. Never updated in place — new version = new row.
model StandardChartVersion {
  id            String   @id @default(uuid()) @db.Uuid
  version       String   @unique
  effectiveDate DateTime @map("effective_date") @db.Date
  chart         Json     @db.JsonB // StandardChart from @finrep/engine
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("standard_chart_versions")
}

/// Per-school, versioned account -> SCoA category mapping. Append-only by
/// (school_id, version) so historical snapshots remain reproducible.
model Mapping {
  id            String   @id @default(uuid()) @db.Uuid
  schoolId      String   @map("school_id") @db.Uuid
  version       String
  effectiveDate DateTime @map("effective_date") @db.Date
  entries       Json     @db.JsonB // account -> SCoA category
  createdAt     DateTime @default(now()) @map("created_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, version])
  @@index([schoolId])
  @@map("mappings")
}

/// DERIVED, reproducible artifact. payload = generateReports() ReportBundle.
/// Reproducible from import.rows + mappingVersion + standardChartVersion +
/// engineVersion (see reproducibility contract at top of file).
model StatementSnapshot {
  id                   String   @id @default(uuid()) @db.Uuid
  schoolId             String   @map("school_id") @db.Uuid
  fiscalPeriodId       String   @map("fiscal_period_id") @db.Uuid
  mappingVersion       String   @map("mapping_version")
  standardChartVersion String   @map("standard_chart_version")
  engineVersion        String   @map("engine_version")
  payload              Json     @db.JsonB // ReportBundle from @finrep/engine
  createdAt            DateTime @default(now()) @map("created_at")

  // Provenance stamp (audit trail / value-versioning). All nullable, no FK/relation
  // (soft refs) — legacy rows are null and fall through to read-time correlation.
  // trigger ∈ manual|upload|quickbooks_sync|scheduled_sync|remap (SnapshotTrigger).
  trigger              String?  @map("trigger")
  sourceImportId       String?  @map("source_import_id")
  triggeredByUserId    String?  @map("triggered_by_user_id")

  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  fiscalPeriod FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([fiscalPeriodId])
  @@map("statement_snapshots")
}

/// MONTHLY actuals (additive "Option B"). One row per (fiscalPeriod, monthKey
/// 'YYYY-MM'), upsert-REPLACE on re-upload. Fuses Import (immutable sourceRows)
/// + StatementSnapshot (derived CY-only ReportBundle payload) because there is
/// exactly one snapshot per (period, monthKey). A monthly TB is AS-OF month-END
/// = cumulative YTD within the fiscal year (Jul–Jun). The annual path is
/// untouched — this model never participates in the annual generate flow.
model MonthlySnapshot {
  id                   String   @id @default(uuid()) @db.Uuid
  schoolId             String   @map("school_id") @db.Uuid
  fiscalPeriodId       String   @map("fiscal_period_id") @db.Uuid
  monthKey             String   @map("month_key") // 'YYYY-MM' (month-END = cumulative YTD)
  sourceName           String   @map("source_name")
  sourceRows           Json     @map("source_rows") @db.JsonB // NormalizedRow[] — immutable input
  rowCount             Int      @map("row_count")
  payload              Json     @db.JsonB // CY-only ReportBundle (generateReports)
  mappingVersion       String   @map("mapping_version")
  standardChartVersion String   @map("standard_chart_version")
  engineVersion        String   @map("engine_version")
  uploadedBy           String?  @map("uploaded_by") @db.Uuid
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  school         School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  fiscalPeriod   FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id], onDelete: Cascade)
  uploadedByUser User?        @relation("MonthlySnapshotUploadedBy", fields: [uploadedBy], references: [id], onDelete: SetNull)

  @@unique([fiscalPeriodId, monthKey]) // upsert key: re-upload a month REPLACES it
  @@index([schoolId])
  @@index([fiscalPeriodId])
  @@map("monthly_snapshots")
}

// ── Billing (SCHEMA ONLY — Stripe LOGIC is Phase 1D) ──────────────────────────

model Subscription {
  id                   String             @id @default(uuid()) @db.Uuid
  schoolId             String             @unique @map("school_id") @db.Uuid
  stripeCustomerId     String?            @map("stripe_customer_id")
  stripeSubscriptionId String?            @map("stripe_subscription_id")
  plan                 String?
  stripePriceId        String?            @map("stripe_price_id")
  status               SubscriptionStatus @default(none)
  currentPeriodEnd     DateTime?          @map("current_period_end")
  trialEnd             DateTime?          @map("trial_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  // Per-module entitlement (additive, NULLABLE). Stored shape: LicensedModule[]
  // i.e. [{ "key": "finance", "tier": "standard" }]. NULL = legacy/un-migrated
  // row → resolved to {finance} (+ core) at READ time (billing.service). NULL is
  // deliberately NOT defaulted to [] in the DB: [] would mean "licensed to
  // nothing" and could lock out an existing active school, whereas NULL must mean
  // "legacy → finance". Written only by the (deferred) Stripe reconciliation; no
  // client DTO accepts it (forbidNonWhitelisted-safe).
  licensedModules      Json?              @map("licensed_modules") @db.JsonB
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ── Audit ─────────────────────────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  schoolId       String?  @map("school_id") @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  action         String
  targetType     String?  @map("target_type")
  targetId       String?  @map("target_id")
  metadata       Json?    @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  school       School?       @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([organizationId])
  @@index([userId])
  @@map("audit_log")
}

// ── Operational data (Phase 4B) ───────────────────────────────────────────────

/// MUTABLE reference data (unlike immutable imports/snapshots): enrollment + aid
/// figures per (school, fiscal period) that don't live in the trial balance.
/// One upserted row per period; audited via audit_log + updated_by/updated_at.
/// Powers the Tier-2 operational analytics metrics (cost per pupil, aid metrics,
/// tuition discount rate). Decimals are converted to plain `number` at the API
/// boundary to match the engine/analytics number convention.
model PeriodOperationalData {
  id                       String   @id @default(uuid()) @db.Uuid
  schoolId                 String   @map("school_id") @db.Uuid
  fiscalPeriodId           String   @map("fiscal_period_id") @db.Uuid
  enrollment               Int?
  enrollmentFte            Decimal? @map("enrollment_fte") @db.Decimal(10, 2)
  studentsOnAid            Int?     @map("students_on_aid")
  financialAidTotal        Decimal? @map("financial_aid_total") @db.Decimal(18, 2)
  /// Phase 5 — actual STAFF FTEs (NOT the student-side enrollmentFte). teachingFte
  /// is the instructional/teaching subset of totalStaffFte. Drives the board KPIs
  /// teachingFte / totalStaffFte / teacherRatio. NULL = not entered. Cross-field
  /// teachingFte <= totalStaffFte enforced in OperationalService.upsert.
  teachingFte              Decimal? @map("teaching_fte") @db.Decimal(10, 2)
  totalStaffFte            Decimal? @map("total_staff_fte") @db.Decimal(10, 2)
  notes                    String?
  /// Phase 2 — anticipated INCOMING (net-new) students by grade from feeder
  /// sources. JSON object keyed by GradeKey (PK0–PK4, K, 1–8) → non-negative
  /// count. Drives the FY-End Forecast's tuition (merged additively into the
  /// driver enrollmentByGrade). NULL = none entered. A free input, NOT a linked school.
  feederEnrollmentByGrade  Json?    @map("feeder_enrollment_by_grade") @db.JsonB
  /// Phase 2 Enrollment Intelligence — the PLANNED enrollment by grade (JSONB keyed
  /// by GradeKey → non-negative count) a school targets for this period. A free input
  /// (does NOT require a full driver budget); its total is one of the plan sources for
  /// the enrollment_vs_plan metric. NULL = no plan entered.
  plannedEnrollmentByGrade Json?    @map("planned_enrollment_by_grade") @db.JsonB
  /// Phase 2 — provenance stamp for a PROMOTED `enrollment` value: the connector/CSV
  /// provider that last filled it (e.g. 'blackbaud', 'oneroster_csv'). NULL when the
  /// value was hand-entered — the promote path NEVER overwrites a manual entry, and
  /// only re-promotes over a value it stamped itself (fill-when-null OR own stamp).
  enrollmentSourceProvider String?  @map("enrollment_source_provider")
  updatedByUserId          String?  @map("updated_by_user_id") @db.Uuid
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  school        School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  fiscalPeriod  FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id], onDelete: Cascade)
  updatedByUser User?        @relation("OperationalUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([schoolId, fiscalPeriodId])
  @@index([schoolId])
  @@index([fiscalPeriodId])
  @@map("period_operational_data")
}

// ── Phase 2A: per-period compliance intake (Florida scholarship AUP) ──────────

/// MUTABLE reference data (one row per school+period, like period_operational_data)
/// holding the short AUP compliance intake — attestation inputs the API passes
/// into the pure @finrep/compliance package to produce the Review Readiness
/// pre-flag. Additive only. `programs` is a Postgres scalar string list (subset of
/// FTC/FES_EO/FES_UA, validated in the DTO + service before it reaches the package).
model PeriodComplianceInputs {
  id                                  String   @id @default(uuid()) @db.Uuid
  schoolId                            String   @map("school_id") @db.Uuid
  fiscalPeriodId                      String   @map("fiscal_period_id") @db.Uuid
  scholarshipFundsReceived            Decimal? @map("scholarship_funds_received") @db.Decimal(18, 2)
  programs                            String[] @default([])
  fundsAtInsuredInstitution           Boolean? @map("funds_at_insured_institution")
  avgDailyBalanceOver250k             Boolean? @map("avg_daily_balance_over_250k")
  bankRatingReviewedTopTwo            Boolean? @map("bank_rating_reviewed_top_two")
  reconciledWithin60Days              Boolean? @map("reconciled_within_60_days")
  reconciliationIndependentlyReviewed Boolean? @map("reconciliation_independently_reviewed")
  doeStatusApproved                   Boolean? @map("doe_status_approved")
  yearsInOperation                    Int?     @map("years_in_operation")
  suretyBondPosted                    Boolean? @map("surety_bond_posted")
  fesuaAnyAccountOver50k              Boolean? @map("fesua_any_account_over_50k")
  notes                               String?
  updatedByUserId                     String?  @map("updated_by_user_id") @db.Uuid
  createdAt                           DateTime @default(now()) @map("created_at")
  updatedAt                           DateTime @updatedAt @map("updated_at")

  school        School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  fiscalPeriod  FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id], onDelete: Cascade)
  updatedByUser User?        @relation("ComplianceInputsUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([schoolId, fiscalPeriodId])
  @@index([schoolId])
  @@index([fiscalPeriodId])
  @@map("period_compliance_inputs")
}

// ── Scholarship disbursements (Phase 2B) ──────────────────────────────────────

/// Funding-organization (Step Up For Students) per-disbursement detail for one
/// (school, period). ONE row per disbursement. Unlike the immutable Phase-1C
/// import rows, this is a REPLACEABLE set (clear-and-reimport + manual add/edit):
/// PUT replaces the whole set, DELETE clears it. The SUM of `amount` is the
/// funding-org's stated "scholarship funds disbursed to the school", reconciled
/// against the recorded scholarshipFundsReceived (Phase 2A) by the pure
/// @finrep/compliance reconcileScholarships(). `program` is one of FTC/FES_EO/
/// FES_UA or null (flagged downstream). `source` is 'upload' | 'manual'.
model ScholarshipDisbursement {
  id             String    @id @default(uuid()) @db.Uuid
  schoolId       String    @map("school_id") @db.Uuid
  fiscalPeriodId String    @map("fiscal_period_id") @db.Uuid
  studentRef     String?   @map("student_ref")
  program        String?
  payDate        DateTime? @map("pay_date") @db.Date
  amount         Decimal   @db.Decimal(18, 2)
  term           String?
  batchRef       String?   @map("batch_ref")
  source         String    @default("upload")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  fiscalPeriod FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id], onDelete: Cascade)

  @@index([schoolId, fiscalPeriodId])
  @@map("scholarship_disbursements")
}

// ── Corrective Action Plan (Phase 2D) ─────────────────────────────────────────

/// User-editable Corrective Action Plan entries — one row per (school, period,
/// ruleId) keyed by the 2A finding's ruleId. The GET endpoint recomputes the live
/// 2A findings, runs the pure scaffoldCorrectiveActionPlan(), and MERGES these
/// saved edits over the scaffold (saved non-null fields win; the scaffold supplies
/// suggested* defaults). A saved row whose finding is no longer material/reportable
/// is flagged resolved/stale (never deleted), so user edits never vanish when a
/// finding self-heals. `status` is 'open' | 'in_progress' | 'complete'.
model PeriodCorrectiveAction {
  id               String    @id @default(uuid()) @db.Uuid
  schoolId         String    @map("school_id") @db.Uuid
  fiscalPeriodId   String    @map("fiscal_period_id") @db.Uuid
  ruleId           String    @map("rule_id")
  observation      String?
  rootCause        String?   @map("root_cause")
  correctiveAction String?   @map("corrective_action")
  responsibleParty String?   @map("responsible_party")
  targetDate       DateTime? @map("target_date") @db.Date
  status           String    @default("open")
  // Soft-archive: a user "dismissed" a resolved/self-healed row so it stops
  // cluttering the plan. Non-null = hidden from the active resolved list (kept
  // for audit / restore). Live (re-flagged) rows ignore this.
  archivedAt       DateTime? @map("archived_at")
  updatedByUserId  String?   @map("updated_by_user_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  school        School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  fiscalPeriod  FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id], onDelete: Cascade)
  updatedByUser User?        @relation("CorrectiveActionUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([schoolId, fiscalPeriodId, ruleId])
  @@index([schoolId, fiscalPeriodId])
  @@map("period_corrective_actions")
}

// ── Phase 2C — Year-End Review Readiness checklist STATE ──────────────────────
//
/// One row per (school, period, item_id) holding the user-editable checklist
/// state. The checklist ITEM definitions are derived purely in @finrep/compliance
/// (buildYearEndChecklist); this table stores only the saved status/notes layered
/// on top. item_id is a built id ('chk_<ruleId>' | 'doc_<slug>') validated by the
/// API against the builder's known ids. Additive only.
model PeriodChecklistItem {
  id              String   @id @default(uuid()) @db.Uuid
  schoolId        String   @map("school_id") @db.Uuid
  fiscalPeriodId  String   @map("fiscal_period_id") @db.Uuid
  itemId          String   @map("item_id")
  status          String   @default("pending") // 'pending' | 'done' | 'na'
  notes           String?
  updatedByUserId String?  @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  school        School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  fiscalPeriod  FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id], onDelete: Cascade)
  updatedByUser User?        @relation("ChecklistUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([schoolId, fiscalPeriodId, itemId])
  @@index([schoolId, fiscalPeriodId])
  @@map("period_checklist_items")
}

/// Cache of the generated AI/rule insight for a period. Keyed by a fingerprint of
/// the metrics that produced it, so repeated dashboard loads reuse the stored text
/// (no LLM re-bill, stable wording) and it regenerates only when the data changes.
model PeriodInsight {
  id             String   @id @default(uuid()) @db.Uuid
  schoolId       String   @map("school_id") @db.Uuid
  fiscalPeriodId String   @map("fiscal_period_id") @db.Uuid
  fingerprint    String
  text           String
  source         String // 'rule' | 'llm'
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  fiscalPeriod FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id], onDelete: Cascade)

  @@unique([schoolId, fiscalPeriodId])
  @@map("period_insights")
}

/// Phase 3 — a period's budgeted top-line figures, for budget-vs-actual. Actuals
/// come from the statement snapshot (total revenue / expenses), so only the
/// budget is stored here. owner/accountant edit; one row per (school, period).
model PeriodBudget {
  id              String   @id @default(uuid()) @db.Uuid
  schoolId        String   @map("school_id") @db.Uuid
  fiscalPeriodId  String   @map("fiscal_period_id") @db.Uuid
  totalRevenue    Decimal? @map("total_revenue") @db.Decimal(18, 2)
  totalExpenses   Decimal? @map("total_expenses") @db.Decimal(18, 2)
  // Phase 3 (robust) — per-category budget lines + forecast assumption.
  // { revenue: {key:amt}, expense: {key:amt}, growthPct: number }
  lines           Json?
  notes           String?
  updatedByUserId String?  @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  fiscalPeriod FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id], onDelete: Cascade)

  @@unique([schoolId, fiscalPeriodId])
  @@map("period_budgets")
}

/// Phase 3 — recurring board-summary email delivery for a school. One per school.
/// A dependency-free interval in ReportScheduleService sends to `recipients` when
/// due (by cadence vs lastSentAt), composing a self-contained board summary.
model ReportSchedule {
  id              String    @id @default(uuid()) @db.Uuid
  schoolId        String    @unique @map("school_id") @db.Uuid
  cadence         String    @default("monthly") // 'weekly' | 'monthly'
  recipients      String    @default("") // comma/newline-separated emails
  enabled         Boolean   @default(false)
  lastSentAt      DateTime? @map("last_sent_at")
  updatedByUserId String?   @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("report_schedules")
}

// Phase 4E — proactive alerts / standing requests. A user (or Penny) sets a
// standing request that the AlertService scheduler evaluates on a 30-min tick and
// emails when due: a scheduled DIGEST (cadence) or an edge-triggered THRESHOLD
// alert (metricKey/operator/threshold). MANY rows per school/user (NOT unique on
// schoolId, unlike ReportSchedule). lastBreached edge-triggers thresholds so a
// metric that stays below the line does not re-email every tick.
model Alert {
  id              String    @id @default(uuid()) @db.Uuid
  schoolId        String    @map("school_id") @db.Uuid
  createdByUserId String?   @map("created_by_user_id") @db.Uuid
  type            String // 'digest' | 'threshold'
  cadence         String? // 'daily' | 'weekly' | 'monthly' (digest only)
  metricKey       String?   @map("metric_key") // e.g. 'days_cash_on_hand' (threshold only)
  operator        String? // 'lt' | 'gt' (threshold only)
  threshold       Float?
  recipientEmail  String    @map("recipient_email") // defaults to creator's email at create time
  enabled         Boolean   @default(true)
  lastSentAt      DateTime? @map("last_sent_at")
  lastValue       Float?    @map("last_value")
  lastBreached    Boolean   @default(false) @map("last_breached") // edge-trigger state
  label           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  school        School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdByUser User?  @relation("AlertCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([enabled])
  @@map("alerts")
}

/// Phase 6 — a school's QuickBooks Online OAuth connection (one per school). Tokens
/// are refreshed on use. NOTE: stored as-is here; encrypt at rest before production.
model QboConnection {
  id                String   @id @default(uuid()) @db.Uuid
  schoolId          String   @unique @map("school_id") @db.Uuid
  realmId           String   @map("realm_id")
  companyName       String?  @map("company_name")
  accessToken       String   @map("access_token")
  refreshToken      String   @map("refresh_token")
  expiresAt         DateTime @map("expires_at")
  environment       String   @default("sandbox")
  connectedByUserId String?  @map("connected_by_user_id") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Automated / scheduled nightly sync (QboSyncSchedulerService). Additive, all
  // defaulted so existing rows inherit auto_sync_enabled=true, needs_reauth=false.
  autoSyncEnabled           Boolean   @default(true)  @map("auto_sync_enabled")
  needsReauth               Boolean   @default(false) @map("needs_reauth")
  lastScheduledSyncAt       DateTime? @map("last_scheduled_sync_at")
  lastScheduledSyncStatus   String?   @map("last_scheduled_sync_status")   // synced|no_data|not_entitled|reauth_required|error|no_actor
  lastScheduledSyncError    String?   @map("last_scheduled_sync_error")    // short message when status=error
  lastScheduledSyncRowCount Int?      @map("last_scheduled_sync_row_count")
  reauthNotifiedAt          DateTime? @map("reauth_notified_at")           // de-dupes the reconnect email per dead-token episode
  autoSyncFailures          Int       @default(0)     @map("auto_sync_failures") // consecutive transient failures (backoff)

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("qbo_connections")
}

/// AR/AP aging — the "as-of" Cash & Collections snapshot. UNLIKE statement
/// snapshots this is NOT a reproducible fiscal-period artifact: it is an as-of
/// capture of open receivables/payables aging, DATED by as_of_date (a same-day
/// re-capture UPSERTS on (school_id, as_of_date), idempotent). Written best-effort
/// at QBO sync time and write-through whenever the /cash page / Penny does a live
/// pull. The briefing reads the LATEST row (by captured_at) DIRECTLY via Prisma;
/// the page/Penny may bypass it with a live pull. Value-safe: only aggregate totals
/// + top-N parties (JSON) are stored — no full open-invoice ledger at rest.
model ArApAgingSnapshot {
  id          String   @id @default(uuid()) @db.Uuid
  schoolId    String   @map("school_id") @db.Uuid
  asOfDate    DateTime @map("as_of_date") @db.Date
  realmId     String?  @map("realm_id")
  environment String   @default("sandbox")
  /// 'aging-detail' (the detail report) | 'entity-fallback' (Invoice/Bill query).
  source      String   @default("aging-detail")
  /// 'sync' | 'page' | 'penny' — what triggered this capture.
  capturedVia String   @map("captured_via")

  // Headline totals as Float (the briefing reads these scalars, no JSON parse).
  arTotal    Float @default(0) @map("ar_total")
  arOverdue  Float @default(0) @map("ar_overdue")
  ar90Plus   Float @default(0) @map("ar_90_plus")
  apTotal    Float @default(0) @map("ap_total")
  apOverdue  Float @default(0) @map("ap_overdue")
  apDueSoon  Float @default(0) @map("ap_due_soon")
  arAccounts Int   @default(0) @map("ar_accounts")   // distinct parties with an open balance
  ar90Count  Int   @default(0) @map("ar_90_count")   // parties with any 90+ open balance
  apVendors  Int   @default(0) @map("ap_vendors")

  // Structured detail as JSON (small; read whole by the page, ignored by the briefing).
  arBuckets Json @map("ar_buckets") @db.JsonB // { current, d1_30, d31_60, d61_90, d90_plus }
  apBuckets Json @map("ap_buckets") @db.JsonB
  arTop     Json @map("ar_top") @db.JsonB     // AgingParty[] (top debtors, capped 8)
  apTop     Json @map("ap_top") @db.JsonB     // AgingParty[] (top creditors, capped 8)

  capturedAt DateTime @default(now()) @map("captured_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, asOfDate])
  @@index([schoolId, capturedAt])
  @@map("ar_ap_aging_snapshots")
}

/// Live cash-flow + reconciliation "trust check" snapshot (sibling of
/// ArApAgingSnapshot). PERIOD-scoped (keyed to the reconciled StatementSnapshot's
/// fiscal period), unlike aging's as-of-now grain — so QuickBooks' native reports
/// cover the SAME [fyStart, periodEnd] window as the computed statements they're
/// reconciled against. The briefing reads the recon scalars DIRECTLY via Prisma
/// (NO QboCashFlowService injection — the module rule). Topology A only.
model CashFlowSnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  schoolId       String   @map("school_id") @db.Uuid
  fiscalPeriodId String   @map("fiscal_period_id") @db.Uuid
  realmId        String?  @map("realm_id")
  environment    String   @default("sandbox")
  /// 'cashflow' (native reports/CashFlow) | 'computed-scf' (derived from our own SCF).
  source         String   @default("cashflow")
  /// 'sync' | 'page' | 'penny' — what triggered this capture.
  capturedVia    String   @map("captured_via")

  // QBO cash-flow breakdown (Float; null when the report is degenerate + no SCF).
  operating   Float? @map("operating")
  investing   Float? @map("investing")
  financing   Float? @map("financing")
  netChange   Float? @map("net_change")

  // Sharpened runway (Float; null when uncomputable — value-safe).
  openingCash  Float? @map("opening_cash")   // QBO BalanceSheet ending cash (current cash)
  monthlyBurn  Float? @map("monthly_burn")   // QBO operating cash ÷ months elapsed in FY (signed)
  runwayMonths Float? @map("runway_months")  // openingCash / |monthlyBurn| when burning; else null

  // Reconciliation scalars (the briefing reads these directly — no JSON parse).
  reconStatus    String  @default("unknown") @map("recon_status") // 'tied'|'differs'|'unknown'
  cashDiff       Float?  @map("cash_diff")        // QBO BS cash − computed cash (STRONG check A)
  netIncomeDiff  Float?  @map("net_income_diff")  // QBO P&L NI − computed netChange (STRONG check B)
  cashChangeDiff Float?  @map("cash_change_diff") // QBO CF net-change − computed scf.netCashChange (LOOSE C)
  cashTie        Boolean? @map("cash_tie")        // A within tie tolerance
  netIncomeTie   Boolean? @map("net_income_tie")  // B within tie tolerance

  // Per-check detail as JSON (page popover reads it; briefing reads the `material` flags).
  detail Json? @db.JsonB // { cash:{qbo,computed,diff,status,note?,material}, net_income:{…}, cash_change:{…} }

  capturedAt DateTime @default(now()) @map("captured_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, fiscalPeriodId])
  @@index([schoolId, capturedAt])
  @@map("cash_flow_snapshots")
}

/// Topology B — ONE QuickBooks company for the whole organization, split by
/// Location (QBO API: Department) or Class. Coexists with per-school
/// QboConnection; a school's own connection always wins at import time.
model OrgQboConnection {
  id                String   @id @default(uuid()) @db.Uuid
  organizationId    String   @unique @map("organization_id") @db.Uuid
  realmId           String   @map("realm_id")
  companyName       String?  @map("company_name")
  accessToken       String   @map("access_token")
  refreshToken      String   @map("refresh_token")
  expiresAt         DateTime @map("expires_at")
  environment       String   @default("sandbox")
  /// Active split dimension: 'department' | 'class'. Mappings are stored per
  /// dimension (both sets kept); only the active dimension is imported.
  dimension         String   @default("department")
  connectedByUserId String?  @map("connected_by_user_id") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Automated / scheduled sync — mirrored on the org connection for FORWARD-COMPAT
  // only. Topology-B org connections are NOT swept in this slice (deferred to the
  // diocesan/org auto-sync work); the fields exist so that path is additive later.
  autoSyncEnabled           Boolean   @default(true)  @map("auto_sync_enabled")
  needsReauth               Boolean   @default(false) @map("needs_reauth")
  lastScheduledSyncAt       DateTime? @map("last_scheduled_sync_at")
  lastScheduledSyncStatus   String?   @map("last_scheduled_sync_status")
  lastScheduledSyncError    String?   @map("last_scheduled_sync_error")
  lastScheduledSyncRowCount Int?      @map("last_scheduled_sync_row_count")
  reauthNotifiedAt          DateTime? @map("reauth_notified_at")
  autoSyncFailures          Int       @default(0)     @map("auto_sync_failures")

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  mappings     OrgQboMapping[]

  @@map("org_qbo_connections")
}

/// One EXPLICIT decision per dimension value: mapped (schoolId set) or ignored
/// (schoolId null). No row = unmapped (needs attention). qboId is the stable
/// QBO entity Id; '__unspecified__' = the report's "Not Specified" column.
/// Many values may map to one school (columns sum). qboName is a display
/// snapshot refreshed on mapping reads.
model OrgQboMapping {
  id           String   @id @default(uuid()) @db.Uuid
  connectionId String   @map("connection_id") @db.Uuid
  dimension    String // 'department' | 'class'
  qboId        String   @map("qbo_id")
  qboName      String   @map("qbo_name")
  schoolId     String?  @map("school_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  connection OrgQboConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  school     School?          @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([connectionId, dimension, qboId])
  @@index([schoolId])
  @@map("org_qbo_mappings")
}

// ── Dashboard customization (Phase 4C) ────────────────────────────────────────

/// PER-SCHOOL dashboard layout config (one row per school; per-user layouts are
/// out of scope for Phase 4). `layout` is an ordered JSONB array of
/// { metricKey, visible, chart?, span? } items validated by
/// @finrep/analytics' validateDashboardLayout before persistence (never stored
/// free-form). When no row exists the API returns a DEFAULT layout (registry
/// canonical order, all visible) with isDefault:true, so the dashboard works out
/// of the box. Owner-only mutation; audited via audit_log.
model AnalyticsDashboard {
  id              String   @id @default(uuid()) @db.Uuid
  schoolId        String   @unique @map("school_id") @db.Uuid
  layout          Json     @db.JsonB // DashboardLayout — ordered, validated array
  updatedByUserId String?  @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  school        School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  updatedByUser User?  @relation("DashboardUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@map("analytics_dashboard")
}

// ── Board Report (Phase 1 — NBOA-style finance-committee packet) ──────────────
//
/// Period-scoped EDITABLE state for the "Board Report" (one row per school+period,
/// mirroring PeriodBudget). The financial numbers are NOT stored here — they are
/// recomputed on every GET .../board-report from the StatementSnapshot + budget +
/// analytics. Only the user's edits live here: per-line variance explanations, the
/// MD&A narrative, the title/committee settings, and the generated stamp.
model BoardReport {
  id              String    @id @default(uuid()) @db.Uuid
  schoolId        String    @map("school_id") @db.Uuid
  fiscalPeriodId  String    @map("fiscal_period_id") @db.Uuid
  reportTitle     String?   @map("report_title")
  committeeName   String?   @map("committee_name")
  granularity     String    @default("annual")
  mdaText         String?   @map("mda_text")
  mdaSource       String?   @map("mda_source") // 'rule' | 'llm' | 'user'
  explanations    Json? // { revenue: {catKey: text}, expense: {catKey: text} }
  generatedAt     DateTime? @map("generated_at")
  updatedByUserId String?   @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  school        School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  fiscalPeriod  FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id], onDelete: Cascade)
  updatedByUser User?        @relation("BoardReportUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([schoolId, fiscalPeriodId])
  @@index([schoolId])
  @@index([fiscalPeriodId])
  @@map("board_reports")
}

// ── Phase 3: Supporting schedules (period-scoped, user-maintained) ────────────
// One JSON-array row per (school, period), mirroring BoardReport. Bulk-replace
// PUT (no per-row CRUD). The Json default '[]' means a never-saved period reads
// as an empty array without null-guards. Server reshapes these into the
// capitalBudget / cashInvestments board-report sections (all totals server-side).

model CapitalSchedule {
  id              String   @id @default(uuid()) @db.Uuid
  schoolId        String   @map("school_id") @db.Uuid
  fiscalPeriodId  String   @map("fiscal_period_id") @db.Uuid
  items           Json     @default("[]") // CapitalItem[] (ordered, see sharedShapes)
  updatedByUserId String?  @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  school        School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  fiscalPeriod  FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id], onDelete: Cascade)
  updatedByUser User?        @relation("CapitalScheduleUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([schoolId, fiscalPeriodId])
  @@index([schoolId])
  @@index([fiscalPeriodId])
  @@map("capital_schedules")
}

model CashSchedule {
  id              String   @id @default(uuid()) @db.Uuid
  schoolId        String   @map("school_id") @db.Uuid
  fiscalPeriodId  String   @map("fiscal_period_id") @db.Uuid
  accounts        Json     @default("[]") // CashAccount[] (ordered, see sharedShapes)
  updatedByUserId String?  @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  school        School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  fiscalPeriod  FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id], onDelete: Cascade)
  updatedByUser User?        @relation("CashScheduleUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([schoolId, fiscalPeriodId])
  @@index([schoolId])
  @@index([fiscalPeriodId])
  @@map("cash_schedules")
}

// Phase 6 — Capital Campaign tracker. Mirrors CapitalSchedule exactly plus a
// nullable campaignName header. One JSON-array row per (school, period); items is
// CampaignItem[] (free-text group, original budget vs current estimate). Server
// reshapes these into the board-report capitalCampaign section (difference =
// budget − estimate; positive = under budget / favorable; all totals server-side).
model CampaignSchedule {
  id              String   @id @default(uuid()) @db.Uuid
  schoolId        String   @map("school_id") @db.Uuid
  fiscalPeriodId  String   @map("fiscal_period_id") @db.Uuid
  campaignName    String?  @map("campaign_name")
  items           Json     @default("[]") // CampaignItem[] (ordered, see sharedShapes)
  updatedByUserId String?  @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  school        School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  fiscalPeriod  FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id], onDelete: Cascade)
  updatedByUser User?        @relation("CampaignScheduleUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([schoolId, fiscalPeriodId])
  @@index([schoolId])
  @@index([fiscalPeriodId])
  @@map("campaign_schedules")
}

// ── Phase 3 Governance v1 — the POLICY REGISTER ──────────────────────────────
//
// One row per policy a school tracks (board/finance/HR/safety/etc.), each with a
// review cadence. SCHOOL-scoped, NOT period-scoped — a policy register is a
// STANDING list (unlike BoardReport/CAP which are per (school, fiscalPeriod)).
// That non-period shape is deliberate: it makes Governance the first briefing
// source driven by a state/deadline (a review cycle) rather than a period metric.
//
// Review status (current | due-soon | overdue | unknown) is COMPUTED from the
// three date/interval inputs by the pure @finrep/compliance review-status
// function — NEVER stored, so it can never drift. Both dates are nullable so a
// half-entered policy computes to an honest 'unknown' (no fabricated review date).
//
// Self-contained: v1 has NO committee/board/meeting/minutes FKs (deferred) so
// those later governance slices are purely additive.
model Policy {
  id                   String    @id @default(uuid()) @db.Uuid
  schoolId             String    @map("school_id") @db.Uuid
  title                String
  // Free text v1 (e.g. 'Financial','HR','Safety','Governance') — schools name
  // their own categories; bounded only by the DTO @MaxLength, not an enum.
  category             String
  status               String    @default("active") // 'active' | 'draft' | 'retired' (lifecycle)
  owner                String? // responsible party/role, free text, nullable
  adoptedDate          DateTime? @map("adopted_date") @db.Date
  lastReviewedDate     DateTime? @map("last_reviewed_date") @db.Date
  reviewIntervalMonths Int       @default(12) @map("review_interval_months")
  notes                String?
  updatedByUserId      String?   @map("updated_by_user_id") @db.Uuid
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  school        School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  updatedByUser User?  @relation("PolicyUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@map("policies")
}

// ── Phase 3 Governance depth — COMMITTEES + MEETINGS ──────────────────────────
// The board-meeting half of the governance module (extends the Policy Register).
// Same sellable 'governance' module; a REGISTER-BASED briefing source (like
// policies), NOT a canonical metric. Mirrors the Policy conventions (uuid pk,
// schoolId Cascade, updatedByUserId SetNull, @db.Date discipline, snake_case).
model Committee {
  id              String   @id @default(uuid()) @db.Uuid
  schoolId        String   @map("school_id") @db.Uuid
  name            String
  // Free text v1 (board|finance|governance|advancement|academic|other) — NOT an enum.
  kind            String   @default("other")
  description     String?
  chair           String?
  active          Boolean  @default(true)
  updatedByUserId String?  @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  school        School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  updatedByUser User?     @relation("CommitteeUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  meetings      Meeting[] // back-ref; deleting a committee SetNulls each meeting.committeeId (meeting history preserved)

  @@index([schoolId])
  @@map("governance_committees")
}

model Meeting {
  id                      String    @id @default(uuid()) @db.Uuid
  schoolId                String    @map("school_id") @db.Uuid
  // NULLABLE FK — a meeting MAY belong to a committee; SetNull so deleting a
  // committee nulls this (never cascades away meeting history). Service validates
  // same-school on create/update.
  committeeId             String?   @map("committee_id") @db.Uuid
  title                   String
  scheduledAt             DateTime  @map("scheduled_at") @db.Date
  location                String?
  status                  String    @default("scheduled") // scheduled|held|cancelled
  agenda                  String?
  minutes                 String?
  decisions               String?
  minutesStatus           String    @default("none") @map("minutes_status") // none|draft|pending_approval|approved
  minutesApprovedAt       DateTime? @map("minutes_approved_at") @db.Date
  minutesApprovedByUserId String?   @map("minutes_approved_by_user_id") @db.Uuid
  updatedByUserId         String?   @map("updated_by_user_id") @db.Uuid
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  school            School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  committee         Committee? @relation(fields: [committeeId], references: [id], onDelete: SetNull)
  minutesApprovedBy User?      @relation("MeetingMinutesApprovedBy", fields: [minutesApprovedByUserId], references: [id], onDelete: SetNull)
  updatedByUser     User?      @relation("MeetingUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([committeeId])
  @@map("governance_meetings")
}

// ── Phase 4 Accreditation v1 — the STANDARDS + EVIDENCE register ───────────────
// The first Phase-4 domain and the SECOND licensable module (after governance),
// gated by the 'accreditation' entitlement. Mirrors the Policy register pattern
// (a module-gated, school-scoped CRUD domain feeding the briefing) but split
// across TWO tables: the framework SKELETON (one AccreditationStandard per
// criterion the reviewer scores) vs. the ARTIFACTS (many AccreditationEvidence
// rows attached to prove each). Coverage = "does standard X have >=1 evidence?",
// a one-to-many — a single flat table could not model the whole point (a standard
// with NO evidence yet, i.e. a coverage GAP).
//
// Tenant scoping + @db.Date UTC-midnight discipline + audit-lite all mirror Policy.
model AccreditationStandard {
  id              String    @id @default(uuid()) @db.Uuid
  schoolId        String    @map("school_id") @db.Uuid
  // Phase 4 depth — SELF-RELATION for a nested standard hierarchy (real accreditor
  // frameworks are trees: domain → standard → indicator). A NULL parentId is a
  // top-level node; a node with NO children is a LEAF (coverage/rating roll up over
  // leaves). onDelete: SetNull → deleting a parent RE-PARENTS its children to
  // top-level (parentId→NULL) rather than cascade-deleting a whole subtree — the
  // safe rule (no accidental mass-delete of a domain's indicators). The service also
  // guards same-school + self-parent + cycles before writing parentId.
  parentId        String?   @map("parent_id") @db.Uuid
  // Framework code, free text v1 (e.g. 'MSA-3','Std 1.2') — schools name their own;
  // bounded only by the DTO @MaxLength, deliberately NOT unique (v1 tolerates dups).
  code            String
  title           String
  // Free text v1 (e.g. 'Governance','Finance','Teaching & Learning'), nullable.
  category        String?
  // Per-standard accreditor RATING (met/partial/not-met lifecycle). TEXT + @default
  // so the migration needs NO backfill — every existing row reads 'not_started'. The
  // DTO @IsIn (STANDARD_RATINGS) + service normalizeRating enforce the closed set;
  // schema.prisma and the DDL stay in lockstep (like the evidence sourceType pattern).
  // 'not_started' | 'not_met' | 'partially_met' | 'met'
  rating          String    @default("not_started")
  // Next scheduled accreditation review/visit date. Unlike a Policy (anchor +
  // interval), this is the review date DIRECTLY (drives "review approaching").
  reviewDate      DateTime? @map("review_date") @db.Date
  owner           String?
  notes           String?
  updatedByUserId String?   @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  school        School                  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  // Self-relation: deleting a parent SETS children's parentId to NULL (re-parent to
  // top-level), NEVER cascade — a subtree is never silently mass-deleted.
  parent        AccreditationStandard?  @relation("AccreditationStandardHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children      AccreditationStandard[] @relation("AccreditationStandardHierarchy")
  updatedByUser User?                   @relation("AccreditationStandardUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  evidence      AccreditationEvidence[]

  @@index([schoolId])
  @@index([schoolId, parentId])
  @@map("accreditation_standards")
}

model AccreditationEvidence {
  id              String    @id @default(uuid()) @db.Uuid
  // DENORMALIZED tenant key (also derivable via standard) so every evidence query
  // filters by schoolId directly — belt-and-suspenders tenant isolation. NEVER
  // trusted from the client: the service copies it from the resolved standard.
  schoolId        String    @map("school_id") @db.Uuid
  standardId      String    @map("standard_id") @db.Uuid
  title           String
  kind            String    @default("document") // 'document' | 'link' | 'note'
  // Phase 4 evidence-linkage — a SOFT link (no FK; heterogeneous targets: a Policy
  // id or a BoardReport id) to an internal operational artifact this evidence was
  // attached FROM. Mirrors the Task.sourceType/sourceRef soft-link precedent. NEVER
  // trusted alone: when sourceType != 'manual' the service validates sourceRef ∈ the
  // path school (a schoolId-scoped findFirst on the source table) BEFORE insert, so a
  // forged/foreign sourceRef → 404 and is never linked. @default("manual") means the
  // migration needs NO backfill — every existing row reads as manual, source_ref NULL.
  sourceType      String    @default("manual") @map("source_type") // 'manual' | 'policy' | 'board_report'
  sourceRef       String?   @map("source_ref") @db.Uuid // Policy.id / BoardReport.id (both @db.Uuid)
  reference       String? // url / doc path / citation, free text, nullable
  notes           String?
  capturedAt      DateTime? @map("captured_at") @db.Date
  createdByUserId String?   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  school        School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  // Deleting a standard drops its evidence (no orphans, coverage recomputes).
  standard      AccreditationStandard @relation(fields: [standardId], references: [id], onDelete: Cascade)
  createdByUser User?                 @relation("AccreditationEvidenceCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([standardId])
  @@map("accreditation_evidence")
}

// ── Phase 4 Facilities v1 — the deferred-maintenance register ─────────────────
// The THIRD licensable module (after governance + accreditation) and another
// read-only domain feeding the prioritised briefing. A school tracks maintenance
// items (priority, status, estimatedCost, targetDate); the briefing surfaces the
// deferred-maintenance backlog ("N high-priority items open, $X backlog") — a
// board/capital matter. Mirrors AccreditationStandard: per-school tenant table,
// @db.Date UTC-midnight discipline, audit-lite createdByUserId.
//
// SEPARATE from CapitalSchedule (per-period capital planning) in v1 — no FK, no
// rollup; linking the register to the capital forecast is deferred.
//
// priority/status are TEXT columns with a @default (free text at DB level); the
// DTO @IsIn enforces the enum (mirrors AccreditationEvidence.kind / Policy.status).
model MaintenanceItem {
  id              String    @id @default(uuid()) @db.Uuid
  schoolId        String    @map("school_id") @db.Uuid
  title           String
  // Free text v1 (e.g. 'Boiler room','Gym roof'), nullable.
  location        String?
  // Free text v1 (e.g. 'HVAC','Roofing','Electrical'), nullable.
  category        String?
  priority        String    @default("medium") // 'low' | 'medium' | 'high' | 'critical'
  status          String    @default("open") // 'open' | 'scheduled' | 'in_progress' | 'resolved'
  // Estimated repair/replacement cost. Decimal(14,2) — money, nullable. Coerced to
  // a JS number in the service's toPublic (Prisma.Decimal never reaches the pure helper).
  estimatedCost   Decimal?  @map("estimated_cost") @db.Decimal(14, 2)
  // ── Facilities depth (additive) — ACTUAL-vs-estimated cost tracking. The realized
  // spend once the work is done. Nullable until closed out; the service surfaces
  // variance (actual − estimated) in the response. Same Decimal→number coercion in
  // toPublic (Prisma.Decimal never reaches the pure helpers). Mirrors estimatedCost.
  actualCost      Decimal?  @map("actual_cost") @db.Decimal(14, 2)
  // ── Facilities depth (additive) — non-PII business/contractor name (e.g. 'ACME HVAC').
  // Free text v1, nullable — NOT an identity of any individual.
  vendor          String?
  // Target/desired-by completion date (drives overdue urgency). @db.Date UTC-midnight.
  targetDate      DateTime? @map("target_date") @db.Date
  // ── Facilities depth (additive) — PREVENTIVE/RECURRING maintenance. MIRRORS the Task
  // recurrence convention EXACTLY (see model Task): recurrence defaults 'none' so every
  // existing row is valid post-migration with NO backfill (a 'none' item never spawns a
  // successor). On the status transition INTO 'resolved', a 'none'!==recurrence item
  // spawns its next occurrence (a fresh open item at the next interval) linked by
  // seriesId; recurrenceUntil bounds the series (null = open-ended, hard-capped in the
  // service). recurrence is a TEXT column with a @default (free text at DB level); the
  // DTO @IsIn enforces the enum and the service normalizes stray reads to 'none'.
  recurrence      String    @default("none") @map("recurrence") // none|weekly|monthly|quarterly|annual
  recurrenceUntil DateTime? @map("recurrence_until") @db.Date
  seriesId        String?   @map("series_id") @db.Uuid
  notes           String?
  createdByUserId String?   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  school        School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdByUser User?  @relation("MaintenanceItemCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  // Series lookups (all occurrences of one recurring item) stay school-scoped.
  @@index([schoolId, seriesId])
  @@map("maintenance_items")
}

// ── Phase 4 Advancement v1 — the fundraising campaign/appeal register ─────────
// The FOURTH (and LAST-uncovered-domain) licensable module. A school-scoped,
// read/write register feeding the prioritised briefing. A school tracks fundraising
// campaigns (goal, raised, close date, status); the briefing surfaces the giving
// progress ("N active campaigns behind goal / closing soon") — a board/development
// matter. Mirrors MaintenanceItem: per-school tenant table, @db.Date UTC-midnight
// discipline, audit-lite createdByUserId.
//
// campaignType/status are TEXT columns (free text at DB level); the DTO @IsIn
// enforces the status enum (mirrors MaintenanceItem.status). raisedAmount is nullable
// (mirrors estimatedCost) — the service defaults an omitted create to 0.
model AdvancementCampaign {
  id              String    @id @default(uuid()) @db.Uuid
  schoolId        String    @map("school_id") @db.Uuid
  name            String
  // Free text v1 (e.g. 'annual_fund' | 'capital' | 'other'), nullable — NOT an enum (stay general).
  campaignType    String?   @map("campaign_type")
  // Fundraising goal. Decimal(14,2) money, nullable. Coerced to a JS number in toPublic.
  goalAmount      Decimal?  @map("goal_amount") @db.Decimal(14, 2)
  // Amount raised so far. Decimal(14,2), nullable (mirrors estimatedCost). Coerced to
  // a JS number in toPublic; the service defaults an omitted create to 0.
  raisedAmount    Decimal?  @map("raised_amount") @db.Decimal(14, 2)
  fiscalYear      Int?      @map("fiscal_year")
  // @db.Date UTC-midnight campaign window.
  startDate       DateTime? @map("start_date") @db.Date
  closeDate       DateTime? @map("close_date") @db.Date
  status          String    @default("active") // 'planned' | 'active' | 'closed'
  notes           String?
  createdByUserId String?   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  school        School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdByUser User?             @relation("AdvancementCampaignCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  gifts         AdvancementGift[]

  @@index([schoolId])
  @@map("advancement_campaigns")
}

// ── Phase 4 Advancement v1 — Gifts & Pledges under a campaign ─────────────────
// CHILD entities of an AdvancementCampaign (mirrors AccreditationEvidence under a
// standard): each row is ONE gift or pledge, so a campaign's "raised" becomes a
// COMPUTED rollup (Σ received_amount) instead of a hand-typed aggregate — with
// pledge-vs-received tracking. DENORMALIZED school_id tenant key (also derivable via
// the campaign) so every gift query filters by schoolId directly — belt-and-suspenders
// tenant isolation, NEVER trusted from the client: the service copies it from the
// resolved campaign. Deleting a campaign cascades its gifts (onDelete: Cascade), so
// "raised" recomputes with no orphans; deleting a user nulls created_by.
//
// AGGREGATE-ONLY / NO per-donor PII (see the AdvancementCampaign comment above): a gift
// row captures amount / kind / status / date + an OPTIONAL non-identifying free-text
// label ('Spring appeal', 'Anonymous major gift') and note/source ONLY. There is
// DELIBERATELY NO donor name / email / address column — the platform does not model
// donors. The DTO caps `label` length and the UI never collects an identity.
//
// kind/status are TEXT columns with a @default (free text at DB level); the DTO @IsIn
// enforces the enum and the service DERIVES status from receivedAmount (0 → 'pledged',
// 0<x<amount → 'partial', ==amount → 'received'; 'written_off' is an explicit override).
// Mirrors MaintenanceItem.status / AdvancementCampaign.status (String, not a Prisma enum
// — the register domains keep enums app-level, unlike the auth domain).
model AdvancementGift {
  id              String   @id @default(uuid()) @db.Uuid
  schoolId        String   @map("school_id") @db.Uuid
  campaignId      String   @map("campaign_id") @db.Uuid
  kind            String   @default("gift") // 'gift' | 'pledge'
  // The gift amount, or the TOTAL pledged amount. Decimal(14,2) money. Coerced to a JS
  // number in the service's toGiftPublic (Prisma.Decimal never reaches the pure helpers).
  amount          Decimal  @db.Decimal(14, 2)
  // How much has actually been received. For a 'gift' == amount on creation; for a
  // 'pledge' it's 0..amount. The campaign rollup sums THIS column into `raised`.
  receivedAmount  Decimal  @default(0) @map("received_amount") @db.Decimal(14, 2)
  status          String   @default("received") // 'received' | 'pledged' | 'partial' | 'written_off'
  // Date of the gift / pledge. @db.Date UTC-midnight (mirrors campaign start/close dates).
  occurredOn      DateTime @map("occurred_on") @db.Date
  // OPTIONAL non-identifying label (e.g. 'Spring appeal'). NEVER a donor name.
  label           String?
  note            String?
  // OPTIONAL provenance (e.g. 'event' | 'online' | 'grant'), free text.
  source          String?
  createdByUserId String?  @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  school        School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  // Deleting a campaign drops its gifts (no orphans, the rollup recomputes).
  campaign      AdvancementCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdByUser User?               @relation("AdvancementGiftCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([campaignId])
  @@map("advancement_gifts")
}

// ── Phase 4 Knowledge document store — the uploaded-file register ──────────────
// The last Phase-4 depth piece: file BYTES live in AWS S3 (server-side upload);
// this row holds the METADATA + an optional soft polymorphic link to an operational
// entity. Knowledge is CORE (always included, NOT a licensed module), so there is no
// module gate. Mirrors AccreditationEvidence's sourceType/sourceRef soft-link (no FK,
// heterogeneous targets) + the denormalized schoolId tenant convention.
//
// s3Key is the object key (prefix/schoolId/documentId/sanitized-name) — namespaced by
// schoolId for tenant isolation in the object store itself; it is NOT a secret
// (download is always via a short-lived presigned GET). @unique per object.
model KnowledgeDocument {
  id               String   @id @default(uuid()) @db.Uuid
  schoolId         String   @map("school_id") @db.Uuid
  title            String
  description      String?
  fileName         String   @map("file_name")
  mimeType         String   @map("mime_type")
  sizeBytes        Int      @map("size_bytes")
  s3Key            String   @unique @map("s3_key")
  tags             String[] @default([])
  // manual|policy|board_report|standard|campaign|maintenance — validated ∈ path school
  // in the service when != 'manual' (mirror AccreditationEvidence link validation).
  sourceType       String   @default("manual") @map("source_type")
  sourceRef        String?  @map("source_ref") @db.Uuid
  uploadedByUserId String?  @map("uploaded_by_user_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  school         School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  uploadedByUser User?  @relation("KnowledgeDocumentUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([schoolId, sourceRef])
  @@map("knowledge_documents")
}

// ── Phase 3 Workflow v1 — the generic TASK engine ─────────────────────────────
// The OTHER half of Phase 3 (pairs with the Policy register): a generic,
// assignable, due-dated task that makes every domain ACTIONABLE. A briefing
// attention item (an overdue policy, an off-band metric) can become a Task, and
// open/overdue Tasks feed BACK into the briefing.
//
// PACKAGING: Workflow is CORE (always included, never a licensed module) — so
// unlike Policy there is no module gate; the controller uses the base entitlement
// only. Mirrors Policy for tenant scoping + audit-lite + @db.Date discipline.
//
// urgency (overdue/due-soon/on-track/none) is COMPUTED at the API boundary by the
// pure @finrep/compliance computeTaskUrgency — NEVER stored, so it can't drift.
// sourceType/sourceRef are SOFT links (no FK — heterogeneous targets: a policyId,
// a metricKey, or a briefing item id) so a task can be spawned from any item.
//
// Self-contained: v1 has NO approval/routing/recurrence/reminder fields (deferred)
// so those later workflow slices are purely additive.
model Task {
  id              String    @id @default(uuid()) @db.Uuid
  schoolId        String    @map("school_id") @db.Uuid
  title           String
  description     String?
  // Nullable FK→users, SET NULL on delete (an unassigned task is legal; deleting
  // a user orphans the assignee rather than the task). VALIDATED as an ACTIVE
  // school membership at write time — never a cross-tenant / non-member user.
  assigneeUserId  String?   @map("assignee_user_id") @db.Uuid
  dueDate         DateTime? @map("due_date") @db.Date
  status          String    @default("open") // 'open' | 'in_progress' | 'done' | 'cancelled'
  priority        String    @default("normal") // 'low' | 'normal' | 'high' (triage hint, not urgency)
  sourceType      String?   @map("source_type") // 'manual' | 'policy' | 'metric' | 'compliance' | 'strategy'
  sourceRef       String?   @map("source_ref") // policyId / metricKey / briefing item id / strategy initiative id (soft link)
  createdByUserId String?   @map("created_by_user_id") @db.Uuid
  completedAt     DateTime? @map("completed_at")
  // ── Phase 3 Workflow v1 approval / sign-off (additive; single-approver). A task
  // carries AT MOST ONE approval at a time, so approval is a set of columns on the
  // Task — NOT a separate Approval table (that is the deferred multi-step design).
  // approvalStatus defaults 'none' so EVERY existing row is valid post-migration
  // with no backfill. approver/decidedBy are SET NULL on user delete (audit history
  // survives), mirroring assignee/createdBy.
  approverUserId  String?   @map("approver_user_id") @db.Uuid
  approvalStatus  String    @default("none") @map("approval_status") // 'none' | 'pending' | 'approved' | 'rejected'
  decidedByUserId String?   @map("decided_by_user_id") @db.Uuid
  decidedAt       DateTime? @map("decided_at")
  decisionNote    String?   @map("decision_note")
  // ── Phase 3 Workflow depth (additive) — recurrence + multi-step approval chain.
  // recurrence defaults 'none' so EVERY existing row is valid post-migration with
  // no backfill. On transition INTO 'done', a 'none'!==recurrence task spawns its
  // next occurrence (a fresh open task) linked by seriesId; recurrenceUntil bounds
  // the series (null = open-ended, hard-capped in the service). approvalSteps is
  // the ordered multi-approver chain (JSON); the scalar approver* columns above
  // remain the DENORMALIZED current-step pointer, so legacy single-approver reads
  // work unchanged (approvalSteps null → legacy path).
  recurrence      String    @default("none") @map("recurrence") // none|weekly|monthly|quarterly|annual
  recurrenceUntil DateTime? @map("recurrence_until") @db.Date
  seriesId        String?   @map("series_id") @db.Uuid
  approvalSteps   Json?     @map("approval_steps")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  school        School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  assignee      User?  @relation("TaskAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  createdByUser User?  @relation("TaskCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approver      User?  @relation("TaskApprover", fields: [approverUserId], references: [id], onDelete: SetNull)
  decidedByUser User?  @relation("TaskDecidedBy", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([schoolId, status])
  @@index([schoolId, approvalStatus])
  @@index([schoolId, seriesId])
  @@map("tasks")
}

// ── Phase 2: Enrollment Intelligence — SIS/roster connector + snapshot series ──

/// The enrollment/SIS providers a school can pull a roster from. `oneroster_csv`
/// and `manual` never create an EnrollmentSource row (they carry a provider stamp
/// on the snapshot instead); the API providers (blackbaud live; oneroster_api /
/// facts / veracross built-to-spec + config-gated dark) store creds in a source.
enum EnrollmentProvider {
  oneroster_csv // universal file/ZIP upload — no stored source row
  oneroster_api // OneRoster 1.1/1.2 REST (dark, config-gated)
  blackbaud // SKY API OAuth2 + subscription key — LIVE-verifiable sandbox
  facts // built-to-spec, config-gated dark
  veracross // built-to-spec, config-gated dark
  manual // hand-entered snapshot
}

/// Phase 2 — LIVE enrollment/SIS connector creds for one school (mirrors
/// QboConnection: exists ONLY when a vendor API is configured). CSV/manual
/// snapshots carry sourceId=null + a provider stamp on the snapshot instead.
model EnrollmentSource {
  id                String             @id @default(uuid()) @db.Uuid
  schoolId          String             @unique @map("school_id") @db.Uuid
  provider          EnrollmentProvider
  accessToken       String?            @map("access_token") // OAuth (blackbaud)
  refreshToken      String?            @map("refresh_token")
  expiresAt         DateTime?          @map("expires_at")
  apiKeyId          String?            @map("api_key_id") // key/basic providers
  apiKeySecret      String?            @map("api_key_secret")
  baseUrl           String?            @map("base_url")
  externalOrgId     String?            @map("external_org_id") // SIS org sourcedId
  subscriptionKey   String?            @map("subscription_key") // Blackbaud SKY
  environment       String             @default("sandbox")
  config            Json?              @db.JsonB
  status            String             @default("connected") // connected | error
  lastError         String?            @map("last_error")
  lastSyncedAt      DateTime?          @map("last_synced_at")
  connectedByUserId String?            @map("connected_by_user_id") @db.Uuid
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  school    School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  snapshots EnrollmentSnapshot[]

  @@map("enrollment_sources")
}

/// Phase 2 — DATED append-only roster observation (the enrollment TIME-SERIES;
/// immutable, unlike the single mutable PeriodOperationalData row). Source-stamped.
model EnrollmentSnapshot {
  id              String             @id @default(uuid()) @db.Uuid
  schoolId        String             @map("school_id") @db.Uuid
  sourceId        String?            @map("source_id") @db.Uuid // null for CSV/manual
  fiscalPeriodId  String?            @map("fiscal_period_id") @db.Uuid
  observedOn      DateTime           @map("observed_on") @db.Date // as-of date (time axis)
  provider        EnrollmentProvider
  totalEnrolled   Int                @map("total_enrolled")
  byGrade         Json               @map("by_grade") @db.JsonB // GradeKey -> count (active)
  byStatus        Json?              @map("by_status") @db.JsonB // {enrolled,withdrawn?,applied?,accepted?}
  fte             Decimal?           @db.Decimal(10, 2)
  raw             Json?              @db.JsonB // rawGradeCounts, droppedRows, warnings
  createdByUserId String?            @map("created_by_user_id") @db.Uuid
  createdAt       DateTime           @default(now()) @map("created_at")

  school        School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  source        EnrollmentSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  fiscalPeriod  FiscalPeriod?     @relation(fields: [fiscalPeriodId], references: [id], onDelete: SetNull)
  createdByUser User?             @relation("EnrollmentSnapshotCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([schoolId, sourceId, observedOn]) // idempotent re-import
  @@index([schoolId, observedOn])
  @@index([fiscalPeriodId])
  @@map("enrollment_snapshots")
}

// ── Phase 5: Strategic Planning — plan → pillar → goal → initiative register ──

/// The 7th sellable module ('strategy'). A school's multi-year strategic plan: a
/// mission + a set of pillars, each holding measurable goals, each with execution
/// initiatives. School-scoped (NOT period-scoped). The ACTIVE plan (the one the
/// briefing/Penny/hero read) = the single `adopted` plan with the newest adoptedAt,
/// else the most-recently-updated `draft`. startDate/endDate/adoptedAt are
/// SERVER-DERIVED (never client fields): startDate = Jul 1 of fyStartYear, endDate =
/// Jun 30 of fyEndYear (FY is Jul–Jun), adoptedAt stamped when status → 'adopted'.
model StrategicPlan {
  id              String    @id @default(uuid()) @db.Uuid
  schoolId        String    @map("school_id") @db.Uuid
  name            String
  mission         String?
  // 'draft' | 'adopted' | 'archived'. @default('draft') → migration needs no backfill.
  status          String    @default("draft")
  fyStartYear     Int       @map("fy_start_year")
  fyEndYear       Int       @map("fy_end_year")
  // Server-derived from the FY years (Jul–Jun); nullable so a lean create still works.
  startDate       DateTime? @map("start_date") @db.Date
  endDate         DateTime? @map("end_date") @db.Date
  // Stamped when status first flips to 'adopted' (drives ACTIVE-plan resolution).
  adoptedAt       DateTime? @map("adopted_at")
  // Client-settable plan-review date (drives the 'plan-review-due' briefing signal).
  nextReviewDate  DateTime? @map("next_review_date") @db.Date
  updatedByUserId String?   @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  school        School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  updatedByUser User?            @relation("StrategicPlanUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  pillars       StrategyPillar[]

  @@index([schoolId])
  @@map("strategic_plans")
}

/// A strategic PILLAR (theme) under a plan — e.g. "Academic Excellence",
/// "Financial Sustainability". Deleting a plan cascade-deletes its pillars.
model StrategyPillar {
  id              String   @id @default(uuid()) @db.Uuid
  schoolId        String   @map("school_id") @db.Uuid
  planId          String   @map("plan_id") @db.Uuid
  name            String
  description     String?
  orderIndex      Int      @default(0) @map("order_index")
  updatedByUserId String?  @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  school        School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  plan          StrategicPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  updatedByUser User?         @relation("StrategyPillarUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  goals         StrategyGoal[]

  @@index([schoolId])
  @@index([planId])
  @@map("strategy_pillars")
}

/// A measurable GOAL under a pillar. goalType selects the progress source:
///   'metric'      — bound to a canonical @finrep/analytics metricKey; current value
///                   is COMPUTED live from the annual snapshot (never typed in), and
///                   the baseline is FROZEN at bind (baselineValue/baselineDate/
///                   baselineMetricPeriodId; persist-on-first-read backfill).
///   'milestone'   — progress = done/total of the milestones JSON [{id,label,done}].
///   'task_rollup' — progress = done/total of the workflow Tasks soft-linked to this
///                   goal's initiatives (Task.sourceType='strategy', sourceRef=initiativeId).
///   'manual'      — progress = manualProgressPct (0..1), set by hand.
/// Percent/share metric targets are stored as a 0..1 fraction (the DTO/service
/// convert). Mix keys (revenue_mix/expense_mix) are REJECTED at bind.
model StrategyGoal {
  id                     String    @id @default(uuid()) @db.Uuid
  schoolId               String    @map("school_id") @db.Uuid
  pillarId               String    @map("pillar_id") @db.Uuid
  title                  String
  description            String?
  // 'metric' | 'milestone' | 'task_rollup' | 'manual'
  goalType               String    @default("metric") @map("goal_type")
  orderIndex             Int       @default(0) @map("order_index")
  // Optional accountable owner — VALIDATED as an active school membership at write.
  ownerUserId            String?   @map("owner_user_id") @db.Uuid
  // Metric binding (goalType='metric' only). metricKey is a canonical MetricKey.
  metricKey              String?   @map("metric_key")
  targetValue            Decimal?  @map("target_value") @db.Decimal(18, 6)
  // Baseline FROZEN at bind (never recomputed "earliest available" on read).
  baselineValue          Decimal?  @map("baseline_value") @db.Decimal(18, 6)
  baselineDate           DateTime? @map("baseline_date") @db.Date
  baselineMetricPeriodId String?   @map("baseline_metric_period_id") @db.Uuid
  startDate              DateTime? @map("start_date") @db.Date
  targetDate             DateTime? @map("target_date") @db.Date
  // goalType='manual' — hand-set progress fraction 0..1.
  manualProgressPct      Decimal?  @map("manual_progress_pct") @db.Decimal(6, 4)
  // goalType='milestone' — [{ id, label, done }] JSON.
  milestones             Json?
  updatedByUserId        String?   @map("updated_by_user_id") @db.Uuid
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  school        School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  pillar        StrategyPillar       @relation(fields: [pillarId], references: [id], onDelete: Cascade)
  owner         User?                @relation("StrategyGoalOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  updatedByUser User?                @relation("StrategyGoalUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  initiatives   StrategyInitiative[]

  @@index([schoolId])
  @@index([pillarId])
  @@map("strategy_goals")
}

/// An execution INITIATIVE under a goal — the "how". Workflow Tasks soft-link to an
/// initiative (Task.sourceType='strategy', sourceRef=initiative.id) to roll up.
model StrategyInitiative {
  id              String   @id @default(uuid()) @db.Uuid
  schoolId        String   @map("school_id") @db.Uuid
  goalId          String   @map("goal_id") @db.Uuid
  title           String
  description     String?
  // 'planned' | 'in_progress' | 'blocked' | 'done' | 'cancelled'
  status          String   @default("planned")
  ownerUserId     String?  @map("owner_user_id") @db.Uuid
  orderIndex      Int      @default(0) @map("order_index")
  updatedByUserId String?  @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  school        School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  goal          StrategyGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  owner         User?        @relation("StrategyInitiativeOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  updatedByUser User?        @relation("StrategyInitiativeUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([goalId])
  @@map("strategy_initiatives")
}
