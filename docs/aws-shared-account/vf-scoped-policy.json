{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "VfDocumentBuckets",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:GetObjectVersion",
        "s3:DeleteObject",
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::villagefinder*-docs",
        "arn:aws:s3:::villagefinder*-docs/*"
      ]
    },
    {
      "Sid": "VfDatabaseBackups",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:GetObjectVersion",
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::villagefinder-main",
        "arn:aws:s3:::villagefinder-main/*"
      ]
    },
    {
      "Sid": "VfEnvConfigBucketReadOnly",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::village-finders-secrets",
        "arn:aws:s3:::village-finders-secrets/*"
      ]
    },
    {
      "Sid": "DenyOurkyroData",
      "Effect": "Deny",
      "Action": ["s3:*", "secretsmanager:*", "rds:*", "rds-db:*", "kms:*"],
      "Resource": [
        "arn:aws:s3:::ourkyro-prod-*",
        "arn:aws:s3:::ourkyro-prod-*/*",
        "arn:aws:secretsmanager:*:785878451144:secret:ourkyro-prod-*",
        "arn:aws:rds:*:785878451144:*:ourkyro-prod-*"
      ]
    }
  ]
}
