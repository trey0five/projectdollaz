# ─────────────────────────────────────────────────────────────────────────────
# finrep — environment template. Copy to `.env` (gitignored) for local dev.
# docker-compose reads this file; the api container also receives it via env_file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Postgres (compose `postgres` service) ──
POSTGRES_USER=finrep
POSTGRES_PASSWORD=finrep_dev_pw
POSTGRES_DB=finrep

# ── Database URL ──
# Inside compose, the api talks to the `postgres` SERVICE on the internal port 5432.
DATABASE_URL=postgresql://finrep:finrep_dev_pw@postgres:5432/finrep?schema=public
# Host-side variant (e.g. running prisma migrate from your machine):
# host port 5434 is mapped to the container's 5432 (5433 is used by smartbot).
# DATABASE_URL=postgresql://finrep:finrep_dev_pw@localhost:5434/finrep?schema=public

# ── API ──
PORT=8000
WEB_ORIGIN=http://localhost:5173

# ── Auth (Phase 1B) ──
# JWT_SECRET MUST be a strong, random value (>= 32 chars) and MUST NOT be the
# old 'changeme-dev-only' default. In production the API FAILS TO START if it is
# unset, the dev default, or shorter than 32 chars. In dev, if you leave it
# blank the API generates a random per-process secret (never a known constant).
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-strong-random-32plus-char-secret-from-the-command-above
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=30d

# ── Email / Mailer (Phase 1B) ──
# Leave SMTP_HOST empty for DEV mode: verification/reset links are logged to the
# api console and the token is kept in the DB (so tests can retrieve it). Set the
# SMTP_* vars to send real email. Example below is Brevo (smtp-relay.brevo.com):
# SMTP_USER is your Brevo SMTP login, SMTP_PASS is your Brevo SMTP key (NOT your
# account password), SMTP_FROM must use a Brevo-verified sender address.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-smtp-login@smtp-brevo.com
SMTP_PASS=your-brevo-smtp-key
SMTP_FROM=Project Dollaz <verified-sender@yourdomain.com>

# ── Seed dev owner (Phase 1B) — log in immediately after `docker compose up` ──
DEV_OWNER_EMAIL=owner@finrep.dev
DEV_OWNER_PASSWORD=Password123!

# ── Stripe subscription billing (Phase 1D) ──
# Leave STRIPE_SECRET_KEY EMPTY for dev/test: the api boots fine, and
# checkout/portal return a clear STRIPE_NOT_CONFIGURED error until you add a real
# key. Webhook verification only needs STRIPE_WEBHOOK_SECRET (pure HMAC — no live
# key), so the locally-signed webhook test works without a secret key.
STRIPE_SECRET_KEY=
# A test webhook secret so the locally-signed webhook test verifies. For live
# Stripe, replace with the signing secret from your webhook endpoint (whsec_...).
STRIPE_WEBHOOK_SECRET=whsec_test_finrep_local_dev_secret
# Price IDs (placeholders — set real price_... ids to enable live checkout).
STRIPE_PRICE_MONTHLY=price_monthly_placeholder
STRIPE_PRICE_YEARLY=price_yearly_placeholder
# Local trial length (days) granted to a new school before it must pay.
STRIPE_TRIAL_DAYS=14
# Checkout / portal redirect URLs (default to WEB_ORIGIN/settings/billing).
# STRIPE_SUCCESS_URL=http://localhost:5173/settings/billing?checkout=success
# STRIPE_CANCEL_URL=http://localhost:5173/settings/billing?checkout=cancel
# STRIPE_PORTAL_RETURN_URL=http://localhost:5173/settings/billing

# ── AI insight summary (Phase 4D) ──
# OPTIONAL. Leave ANTHROPIC_API_KEY EMPTY for dev/test: the AI insight band falls
# back to the deterministic, always-on rule-based summary ({ source: "rule" }) and
# the api boots fine. Set a real sk-ant-... key to upgrade insights to a richer
# Claude narrative ({ source: "llm" }); on any error it gracefully falls back.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# ── Penny voice replies / text-to-speech (ElevenLabs) ──
# OPTIONAL. Leave ELEVENLABS_API_KEY EMPTY for dev/test: the /assistant/tts proxy
# returns 503 and Penny's voice falls back to the browser SpeechSynthesis API, so
# spoken replies work out-of-the-box. Set a real key to upgrade to ElevenLabs
# (the key stays server-side; the frontend never sees it).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=
